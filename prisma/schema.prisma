generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

/**
 *  Subject: Mathematics
 *  └── Unit: Algebra (type: course)
 *      ├── Unit: Linear Equations (type: chapter)
 *      │   ├── Unit: Solving Simple Equations (type: lesson)
 *      │   └── Unit: Word Problems (type: lesson)
 *      └── Unit: Quadratic Equations (type: chapter)
 *          ├── Unit: Factoring (type: lesson)
 *          └── Unit: Quadratic Formula (type: lesson)
 */
model MemoryCheck {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  memoryPiece String   @db.ObjectId
  memory      MemoryPiece @relation(fields: [memoryPiece], references: [id], onDelete: NoAction, onUpdate: NoAction)
  correct     Boolean
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("memorychecks")
}

model Unit {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  type        String    // e.g., "chapter", "lesson", "module"
  description String?
  parentUnit  String?   @db.ObjectId
  parent      Unit?     @relation("UnitHierarchy", fields: [parentUnit], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children    Unit[]    @relation("UnitHierarchy")
  subject     String    @db.ObjectId
  subjectRef  Subject   @relation(fields: [subject], references: [id])
  order       Int       // To maintain sequence within parent
  memoryPieces MemoryPiece[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("units")
}

model MemoryPiece {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  subject      String        @db.ObjectId
  subjectRef   Subject       @relation(fields: [subject], references: [id])
  unit         String        @db.ObjectId
  unitRef      Unit          @relation(fields: [unit], references: [id])
  content      String        @unique(map: "content_1")
  imageUrl     String
  description  String
  labels       String[]
  memoryChecks MemoryCheck[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("memorypieces")
}

model Subject {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  description  String
  labels       String[]
  units        Unit[]
  memoryPieces MemoryPiece[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("subjects")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  memoryChecks  MemoryCheck[] // Add this relation

  @@map("users")
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}
